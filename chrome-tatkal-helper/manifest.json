{
  "manifest_version": 3,
  "name": "Tatkal Booking Assistant",
  "version": "1.0.0",
  "description": "Helps prefill Tatkal booking details and sets opening-time reminders.",
  "permissions": ["storage", "alarms", "notifications", "tabs"],
  "host_permissions": [
    "https://www.irctc.co.in/*",
    "https://www.irctc.co.in/nget/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Tatkal Booking Assistant",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://www.irctc.co.in/*", "https://www.irctc.co.in/nget/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
